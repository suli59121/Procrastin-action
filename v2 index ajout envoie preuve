<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Procrastin'Action - Bêta</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f4f4f9; padding-top: 50px; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); display: inline-block; max-width: 400px; width: 90%; }
        h1 { color: #2c3e50; margin-bottom: 10px; }
        #desc { font-size: 1.2rem; color: #34495e; margin: 20px 0; min-height: 50px; font-weight: bold; }
        .btn-next { background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; transition: 0.3s; width: 100%; }
        .btn-next:hover { background: #2980b9; }
        
        /* Nouveau style pour la zone de preuve */
        #proof-section { margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee; display: none; }
        textarea { width: 100%; border: 1px solid #ddd; border-radius: 5px; padding: 10px; resize: none; margin-bottom: 10px; box-sizing: border-box; }
        .btn-send { background: #2ecc71; color: white; border: none; padding: 10px; border-radius: 5px; cursor: pointer; width: 100%; }
        .btn-send:hover { background: #27ae60; }

        .btn-panic { background: #e74c3c; color: white; padding: 10px; margin-top: 30px; cursor: pointer; border-radius: 5px; display: inline-block; }
        #boss-mode { display: none; background: white; position: fixed; top:0; left:0; width:100%; height:100%; z-index: 1000; padding: 50px; text-align: left; overflow-y: auto; }
    </style>
</head>
<body>

    <div id="game-ui">
        <div class="card">
            <h1>Procrastin'Action</h1>
            <p>Ton défi actuel :</p>
            <div id="desc">Prêt pour une petite pause ?</div>
            <button class="btn-next" onclick="getChallenge()">✨ Nouveau Défi</button>

            <div id="proof-section">
                <textarea id="proofInput" rows="3" placeholder="Prouve ton exploit (ex: 'Fait avec mon voisin de bureau !')"></textarea>
                <button class="btn-send" onclick="sendProof()">📤 Envoyer ma preuve</button>
            </div>
        </div>
        <br>
        <div class="btn-panic" onclick="togglePanic()">⚠️ ALERTE PATRON</div>
    </div>

    <div id="boss-mode">
        <h2>Rapport de Performance Trimestriel - Confidentiel</h2>
        <hr>
        <p>Analyse l'evolution de l'efficacité des employés </p>
        <table border="1" style="width:100%">
            <tr><th>post</th><th>pourcentage</th><th>etat</th></tr>
            <tr><td>pc1</td><td>+12.4%</td><td>augmentation</td></tr>
            <tr><td>pc2</td><td>-2.1%</td><td>legere baisse</td></tr>
            <tr><td>pc3</td><td>0%</td><td>stable</td></tr>
            <tr><td>pc4</td><td>-22.41%</td><td>grosse baisse</td></tr>
            <tr><td>pc5</td><td>+2.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc6</td><td>+72.1%</td><td>grosse augmentation</td></tr>
            <tr><td>pc7</td><td>-0.1%</td><td>stable</td></tr>
            <tr><td>pc8</td><td>+12.8%</td><td>augmentation</td></tr>
            <tr><td>pc9</td><td>+7.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc10</td><td>new</td><td>nouvel employé</td></tr>
        </table>
        <p style="margin-top: 50px; color: gray;">(Appuie sur la touche <b>'P'</b> pour revenir au "travail")</p>
    </div>

    <script>
        let currentChallengeId = null; // Pour stocker l'ID du défi en cours

        async function getChallenge() {
            try {
                const res = await fetch('/api/challenge'); 
                if (!res.ok) throw new Error('Erreur réseau');
                
                const data = await res.json();
                
                currentChallengeId = data.id; // On garde l'ID
                document.getElementById('desc').innerText = data.description + " (" + data.points_reward + " pts)";
                
                // On affiche le formulaire de preuve
                document.getElementById('proof-section').style.display = 'block';
                document.getElementById('proofInput').value = ""; // On vide le texte précédent
            } catch (error) {
                console.error("Erreur :", error);
                document.getElementById('desc').innerText = "Erreur de connexion au serveur.";
            }
        }

        // FONCTION POUR ENVOYER LA PREUVE AU SERVEUR
        async function sendProof() {
            const proofText = document.getElementById('proofInput').value;
            
            if (!proofText.trim()) {
                alert("Écris quelque chose pour prouver ton défi !");
                return;
            }

            try {
                const response = await fetch('/api/proof', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        challenge_id: currentChallengeId,
                        user_id: 1, // On utilise l'utilisateur 1 par défaut pour l'instant
                        proof_text: proofText
                    })
                });

                if (response.ok) {
                    alert("✅ Preuve envoyée ! Tes collègues vont pouvoir voter.");
                    document.getElementById('proof-section').style.display = 'none';
                    document.getElementById('desc').innerText = "Défi accompli ! Un autre ?";
                } else {
                    alert("Erreur lors de l'envoi.");
                }
            } catch (error) {
                console.error("Erreur envoi preuve :", error);
            }
        }

        function togglePanic() { document.getElementById('boss-mode').style.display = 'block'; }

        window.addEventListener('keydown', (e) => {
            if(e.key.toLowerCase() === 'p') {
                document.getElementById('boss-mode').style.display = 'none';
            }
        });
    </script>
</body>
</html>
