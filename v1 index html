<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Procrastin'Action - Bêta</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f4f4f9; padding-top: 50px; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); display: inline-block; max-width: 400px; }
        h1 { color: #2c3e50; }
        #desc { font-size: 1.2rem; color: #34495e; margin: 20px 0; min-height: 50px; }
        .btn-next { background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; transition: 0.3s; }
        .btn-next:hover { background: #2980b9; }
        .btn-panic { background: #e74c3c; color: white; padding: 10px; margin-top: 30px; cursor: pointer; border-radius: 5px; display: inline-block; }
        #boss-mode { display: none; background: white; position: fixed; top:0; left:0; width:100%; height:100%; z-index: 1000; padding: 50px; text-align: left; }
    </style>
</head>
<body>

    <div id="game-ui">
        <div class="card">
            <h1>Procrastin'Action</h1>
            <p>Ton défi actuel :</p>
            <div id="desc">Prêt pour une petite pause ?</div>
            <button class="btn-next" onclick="getChallenge()">✨ Nouveau Défi</button>
        </div>
        <br>
        <div class="btn-panic" onclick="togglePanic()">⚠️ ALERTE PATRON</div>
    </div>

    <div id="boss-mode">
        <h2>Rapport de Performance Trimestriel - Confidentiel</h2>
        <hr>
        <p>Analyse l'evolution de l'efficacité des employés </p>
        <table border="1" style="width:100%">
            <tr><th>post</th><th>pourcentage</th><th>etat</th></tr>
            <tr><td>pc1</td><td>+12.4%</td><td>augmentation</td></tr>
            <tr><td>pc2</td><td>-2.1%</td><td>legere baisse</td></tr>
            <tr><td>pc3</td><td>0%</td><td>stable</td></tr>
            <tr><td>pc4</td><td>-22.41%</td><td>grosse baisse</td></tr>
            <tr><td>pc5</td><td>+2.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc6</td><td>+72.1%</td><td>grosse augmentation</td></tr>
            <tr><td>pc7</td><td>-0.1%</td><td>stable</td></tr>
            <tr><td>pc8</td><td>+12.8%</td><td>augmentation</td></tr>
            <tr><td>pc9</td><td>+7.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc10</td><td>new</td><td>nouvel employé</td></tr>
        </table>
        <p style="margin-top: 50px; color: gray;">(Appuie sur la touche <b>'P'</b> pour revenir au "travail")</p>
    </div>

    <script>
        // FONCTION CRUCIALE : Elle appelle ton API Node.js
        async function getChallenge() {
    try {
        const res = await fetch('/api/challenge'); 
        if (!res.ok) throw new Error('Erreur réseau');
        
        const data = await res.json();
        
        // On affiche la description et les points
        document.getElementById('desc').innerText = data.description + " (" + data.points_reward + " pts)";
    } catch (error) {
        console.error("Erreur détaillée :", error);
        document.getElementById('desc').innerText = "Impossible de charger un défi. Vérifie la console (F12).";
    }
}

        // Système de Panic Button
        function togglePanic() {
            document.getElementById('boss-mode').style.display = 'block';
        }

        window.addEventListener('keydown', (e) => {
            if(e.key.toLowerCase() === 'p') {
                document.getElementById('boss-mode').style.display = 'none';
            }
        });
    </script>
</body>
</html>
