<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Procrastin'Action - Bêta</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f4f4f9; padding-top: 50px; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); display: inline-block; max-width: 400px; width: 90%; }
        h1 { color: #2c3e50; margin-bottom: 10px; }
        #desc { font-size: 1.2rem; color: #34495e; margin: 20px 0; min-height: 50px; font-weight: bold; }
        
        .btn-next { background: #3498db; color: white; border: none; padding: 12px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; transition: 0.3s; width: 100%; font-weight: bold; }
        .btn-next:hover { background: #2980b9; }
        
        /* Section Preuve */
        #proof-section { margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee; display: none; }
        textarea { width: 100%; border: 1px solid #ddd; border-radius: 5px; padding: 10px; resize: none; margin-bottom: 10px; box-sizing: border-box; font-family: inherit; }
        .btn-send { background: #2ecc71; color: white; border: none; padding: 10px; border-radius: 5px; cursor: pointer; width: 100%; font-weight: bold; }
        .btn-send:hover { background: #27ae60; }

        .btn-panic { background: #bfb7b6; color: white; padding: 10px 20px; margin-top: 30px; cursor: pointer; border-radius: 5px; display: inline-block; font-weight: bold; }
        
        /* Mode Patron */
        #boss-mode { display: none; background: white; position: fixed; top:0; left:0; width:100%; height:100%; z-index: 10000; padding: 50px; text-align: left; overflow-y: auto; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f2f2f2; }
    </style>
</head>
<body>

    <div id="game-ui">
        <div class="card">
            <div id="user-info" style="font-size: 0.8rem; color: #7f8c8d; margin-bottom: 10px; text-align: right;">Chargement...</div>
            
            <h1>Procrastin'Action</h1>
            <p>Ton défi actuel :</p>
            <div id="desc">Prêt pour une petite pause ?</div>
            
            <button class="btn-next" onclick="getChallenge()">✨ Nouveau Défi</button>

            <div id="proof-section">
                <textarea id="proofInput" rows="3" placeholder="Prouve ton exploit ici..."></textarea>
                <button class="btn-send" onclick="sendProof()">📤 Envoyer ma preuve</button>
            </div>
        </div>
        <br>
        <div class="btn-panic" onclick="togglePanic()">⚠️ ALERTE PATRON</div>
    </div>

    <div id="boss-mode">
        <h2>Rapport de Performance Trimestriel - Confidentiel</h2>
        <hr>
        <p>Analyse l'evolution de l'efficacité des employés </p>
        <table border="1" style="width:100%">
            <tr><th>post</th><th>pourcentage</th><th>etat</th></tr>
            <tr><td>pc1</td><td>+12.4%</td><td>augmentation</td></tr>
            <tr><td>pc2</td><td>-2.1%</td><td>legere baisse</td></tr>
            <tr><td>pc3</td><td>0%</td><td>stable</td></tr>
            <tr><td>pc4</td><td>-22.41%</td><td>grosse baisse</td></tr>
            <tr><td>pc5</td><td>+2.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc6</td><td>+72.1%</td><td>grosse augmentation</td></tr>
            <tr><td>pc7</td><td>-0.1%</td><td>stable</td></tr>
            <tr><td>pc8</td><td>+12.8%</td><td>augmentation</td></tr>
            <tr><td>pc9</td><td>+7.1%</td><td>legere augmentation</td></tr>
            <tr><td>pc10</td><td>new</td><td>nouvel employé</td></tr>
        </table>
        <p style="margin-top: 50px; color: gray;">(Appuie sur la touche <b>'P'</b> pour revenir au "travail")</p>
    </div>

    <script>
        let currentChallengeId = null;
        let currentUserId = null;
        let currentUsername = "";

        // Initialisation : Pseudo + Récupération du score
        async function initApp() {
            currentUsername = prompt("Entre ton pseudo :");
            if (!currentUsername) currentUsername = "Anonyme";

            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: currentUsername })
                });
                const data = await res.json();
                currentUserId = data.id;
                
                // On affiche les points réels venant de la base
                updateScoreUI(data.points_total);
            } catch (err) {
                console.error("Erreur init:", err);
            }
        }

        // Met à jour le texte du score en haut de la carte
        function updateScoreUI(points) {
            document.getElementById('user-info').innerText = `Utilisateur : ${currentUsername} | Points : ${points}`;
        }

        async function getChallenge() {
            try {
                const res = await fetch('/api/challenge'); 
                const data = await res.json();
                currentChallengeId = data.id;
                document.getElementById('desc').innerText = data.description + " (" + data.points_reward + " pts)";
                document.getElementById('proof-section').style.display = 'block';
                document.getElementById('proofInput').value = ""; 
            } catch (error) {
                console.error(error);
            }
        }

        async function sendProof() {
            const text = document.getElementById('proofInput').value;
            if (!text.trim()) return alert("Ajoute une description !");

            try {
                const response = await fetch('/api/proof', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        challenge_id: currentChallengeId,
                        user_id: currentUserId,
                        proof_text: text
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    alert("✅ Succès ! +" + data.pointsGagnes + " points.");
                    
                    // On rafraîchit les points immédiatement en refaisant un petit login
                    const resUser = await fetch('/api/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ username: currentUsername })
                    });
                    const userData = await resUser.json();
                    updateScoreUI(userData.points_total);

                    document.getElementById('proof-section').style.display = 'none';
                    document.getElementById('desc').innerText = "Défi validé ! Un autre ?";
                }
            } catch (error) {
                console.error("Erreur:", error);
            }
        }

        function togglePanic() { document.getElementById('boss-mode').style.display = 'block'; }
        window.addEventListener('keydown', (e) => {
            if (e.key.toLowerCase() === 'p') document.getElementById('boss-mode').style.display = 'none';
        });

        // Lancement au démarrage
        initApp();
    </script>
</body>
</html>
